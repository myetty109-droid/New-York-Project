---
const pageTitle = "New York Test";
---
<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      :root {
        --canvas:  #edebe4;
        --brown:   #1c1412;
        --orange:  #e24d3a;
        --white:   #ffffff;
        --gray:    #5c524f;
        --light:   #f5f3ee;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: var(--canvas);
        color: var(--brown);
        font-family: 'Noto Sans KR', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      /* ───────────────────────────────────────
         SHARED LAYOUT
      ─────────────────────────────────────── */
      .page-wrapper {
        max-width: 960px;
        width: 100%;
        margin: 0 auto;
        padding: 48px 24px 80px;
      }

      .back-btn {
        display: inline-block;
        color: var(--brown);
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        border-bottom: 2px solid var(--brown);
        margin-bottom: 40px;
        transition: color 0.2s, border-color 0.2s;
      }
      .back-btn:hover { color: var(--orange); border-color: var(--orange); }

      .page-title {
        font-family: 'Playfair Display', serif;
        font-size: 2.6rem;
        font-weight: 500;
        letter-spacing: 0.05rem;
        margin-bottom: 10px;
        line-height: 1.2;
      }
      .page-subtitle {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1.05rem;
        color: var(--gray);
        margin-bottom: 48px;
      }

      .section-divider {
        display: flex;
        align-items: center;
        gap: 16px;
        margin: 64px 0 40px;
      }
      .section-divider h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.3rem;
        font-weight: 500;
        letter-spacing: 0.15rem;
        white-space: nowrap;
      }
      .section-divider::after {
        content: '';
        flex: 1;
        height: 2px;
        background: var(--orange);
      }

      /* ───────────────────────────────────────
         SECTION 1 — TALLY SURVEY
      ─────────────────────────────────────── */
      .tally-wrapper {
        width: 100%;
        border: 2px solid var(--brown);
        border-radius: 8px;
        background-color: var(--white);
        overflow: hidden;
      }

      iframe[data-tally-src] {
        width: 100%;
        min-height: 600px;
        height: auto;
        border: none;
        display: block;
      }

      /* ───────────────────────────────────────
         SECTION 2 — GEPHI ANALYSIS
      ─────────────────────────────────────── */
      .analysis-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 32px;
        align-items: start;
      }

      .analysis-image-wrap {
        border: 2px solid var(--brown);
        border-radius: 8px;
        overflow: hidden;
        background: var(--white);
        position: relative;
        cursor: zoom-in;
      }

      .analysis-image-wrap img {
        width: 100%;
        display: block;
        object-fit: cover;
        transition: opacity 0.2s;
      }
      .analysis-image-wrap:hover img { opacity: 0.88; }

      .zoom-hint {
        position: absolute;
        bottom: 10px;
        right: 10px;
        background: rgba(28,20,18,0.7);
        color: #fff;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.06rem;
        padding: 4px 9px;
        border-radius: 20px;
        pointer-events: none;
      }

      .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.85);
        z-index: 9999;
        justify-content: center;
        align-items: center;
        cursor: zoom-out;
      }
      .lightbox.open { display: flex; }
      .lightbox img {
        max-width: 92vw;
        max-height: 92vh;
        object-fit: contain;
        border-radius: 6px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.5);
      }
      .lightbox-close {
        position: absolute;
        top: 20px;
        right: 28px;
        color: #fff;
        font-size: 2rem;
        font-weight: 300;
        cursor: pointer;
        line-height: 1;
        background: none;
        border: none;
      }

      .image-placeholder {
        width: 100%;
        aspect-ratio: 4 / 3;
        background: #e8e5de;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 8px;
        color: var(--gray);
        font-size: 0.85rem;
      }
      .image-placeholder span { font-size: 2rem; }

      .analysis-text h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 500;
        margin-bottom: 12px;
        line-height: 1.3;
      }
      .analysis-text p {
        font-size: 0.88rem;
        line-height: 1.85;
        color: #3a3330;
        margin-bottom: 12px;
      }
      .analysis-text p:last-of-type { margin-bottom: 16px; }
      .analysis-tag {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08rem;
        color: var(--orange);
        border: 1.5px solid var(--orange);
        border-radius: 20px;
        padding: 3px 10px;
        margin-right: 6px;
        margin-bottom: 6px;
      }

      /* ───────────────────────────────────────
         SECTION 3 — DATA VISUALIZATION
      ─────────────────────────────────────── */
      .viz-metric-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 12px;
        margin-bottom: 32px;
      }
      .viz-metric {
        background: var(--white);
        border: 2px solid var(--brown);
        border-radius: 8px;
        padding: 16px 18px;
      }
      .viz-metric-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.08rem;
        color: var(--gray);
        margin-bottom: 6px;
      }
      .viz-metric-value {
        font-family: 'Playfair Display', serif;
        font-size: 1.8rem;
        font-weight: 500;
        color: var(--brown);
        line-height: 1;
      }
      .viz-metric-sub {
        font-size: 0.75rem;
        color: var(--gray);
        margin-top: 4px;
      }

      .viz-chart-label {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        color: var(--gray);
        margin-bottom: 12px;
      }

      .viz-legend {
        display: flex;
        gap: 16px;
        margin-bottom: 10px;
        flex-wrap: wrap;
      }
      .viz-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.78rem;
        color: var(--gray);
      }
      .viz-legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 2px;
        flex-shrink: 0;
      }

      .viz-chart-wrap {
        background: var(--white);
        border: 2px solid var(--brown);
        border-radius: 8px;
        padding: 20px 24px;
        margin-bottom: 20px;
      }

      .viz-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
      }

      /* ───────────────────────────────────────
         SECTION 4 — 11 TYPE ARCHIVE
      ─────────────────────────────────────── */
      .card-color-01 { background: #f5f0d0; }
      .card-color-02 { background: #ecdfc8; }
      .card-color-03 { background: #d6eaf2; }
      .card-color-04 { background: #f5d9d3; }
      .card-color-05 { background: #d4ede6; }
      .card-color-06 {
        background-color: #f8f7f4;
        background-image: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 10px,
          rgba(60, 50, 40, 0.13) 10px,
          rgba(60, 50, 40, 0.13) 11px
        );
      }
      .card-color-07 { background: #f5dde8; }
      .card-color-08 { background: #ece4c0; }
      .card-color-09 { background: #e8dff5; }
      .card-color-10 { background: #e8e6e3; }
      .card-color-11 { background: linear-gradient(135deg, #e4daf5 0%, #cfe8f5 100%); }

      .type-intro {
        font-size: 0.9rem;
        line-height: 1.8;
        color: var(--gray);
        max-width: 680px;
        margin-bottom: 36px;
      }

      .type-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        align-items: stretch;
      }

      .type-card {
        border: 2px solid var(--brown);
        border-radius: 10px;
        padding: 20px 18px;
        background: var(--light);
        display: flex;
        flex-direction: column;
        height: 100%;
      }

      .type-number {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        color: var(--orange);
        margin-bottom: 6px;
      }
      .type-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.05rem;
        font-weight: 500;
        line-height: 1.3;
        min-height: 2.6rem;
      }

      .type-card-img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        border-radius: 6px;
        margin-bottom: 14px;
        display: block;
        background: #ffffff;
      }

      .type-card-link {
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
      }
      .type-card-link .type-card {
        transition: transform 0.25s ease, box-shadow 0.25s ease;
        cursor: pointer;
        flex: 1;
      }
      .type-card-link:hover .type-card {
        transform: translateY(-6px);
        box-shadow: 0 12px 28px rgba(28, 20, 18, 0.12);
      }

      /* ───────────────────────────────────────
         RESPONSIVE
      ─────────────────────────────────────── */
      @media (max-width: 720px) {
        .analysis-grid { grid-template-columns: 1fr; }
        .type-grid { grid-template-columns: repeat(2, 1fr); }
        .page-title { font-size: 2rem; }
        .viz-metric-row { grid-template-columns: repeat(2, 1fr); }
        .viz-two-col { grid-template-columns: 1fr; }
      }

      @media (max-width: 480px) {
        .type-grid { grid-template-columns: 1fr; }
        .viz-metric-row { grid-template-columns: repeat(2, 1fr); }
      }
    </style>

    <script src="https://tally.so/widgets/embed.js" async></script>
  </head>

  <body>
    <div class="page-wrapper">

      <a href="/" class="back-btn">← BACK TO HOMEPAGE</a>

      <h1 class="page-title">New York Test</h1>
      <p class="page-subtitle">Find out what type of city observer you are!</p>


      <!-- ══════════════════════════════════════
           SECTION 1 · SURVEY
      ══════════════════════════════════════ -->
      <div class="section-divider"><h2>TAKE THE SURVEY</h2></div>

      <div class="tally-wrapper">
        <iframe
          data-tally-src="https://tally.so/r/vGKA4d?hideTitle=1&transparentBackground=0"
          loading="lazy"
          title="Digital Logic & Intimacy Survey">
        </iframe>
      </div>


      <!-- ══════════════════════════════════════
           SECTION 2 · GEPHI ANALYSIS
      ══════════════════════════════════════ -->
      <div class="section-divider"><h2>NETWORK ANALYSIS</h2></div>

      <div class="analysis-grid">

        <div class="analysis-image-wrap" id="gephi-thumb" onclick="document.getElementById('gephi-lightbox').classList.add('open')">
          <img
            src="/gephi-network.png"
            alt="Gephi network visualization"
            onerror="this.parentElement.innerHTML='<div class=\'image-placeholder\'><span>🕸</span><span>Add gephi-network.png to /public</span></div>'"
          />
          <div class="zoom-hint">🔍 Click to enlarge</div>
        </div>

        <div class="analysis-text">
          <h3>How does visual perception cluster?</h3>
          <p>
            The network graph visualized in the image maps how abstract concepts and qualitative attributes interconnect within collective perception when individuals evaluate visual imagery. The force-directed layout positions Refined, Local, and Global as the central, most heavily weighted hubs, indicating that these attributes serve as primary anchor points that bridge contrasting conceptual realms.
          </p>
          <p>
            Specifically, these dominant hubs form strong associative paths that connect structured, institutional dimensions, such as Order, Anonymous, and Deliberate, with deeply emotional or spatial dualities, including Freedom, Intimate, and Nostalgic. In contrast, the small, peripheral Raw node on the far left represents a highly isolated attribute with weak connectivity, showing that unrefined or unprocessed qualities are rarely associated with the other dominant descriptors in this collective semantic framework.
          </p>
          <div>
            <span class="analysis-tag">N = 00</span>
            <span class="analysis-tag">Gephi 0.10</span>
            <span class="analysis-tag">ForceAtlas2</span>
            <span class="analysis-tag">Modularity Clustering</span>
          </div>
        </div>
      </div>

      <div class="lightbox" id="gephi-lightbox" onclick="this.classList.remove('open')">
        <button class="lightbox-close" onclick="document.getElementById('gephi-lightbox').classList.remove('open')">×</button>
        <img src="/gephi-network.png" alt="Gephi network visualization enlarged" />
      </div>


      <!-- ══════════════════════════════════════
           SECTION 3 · DATA VISUALIZATION
      ══════════════════════════════════════ -->
      <div class="section-divider"><h2>DATA VISUALIZATION</h2></div>

      <!-- 요약 수치 -->
      <div class="viz-metric-row">
        <div class="viz-metric">
          <div class="viz-metric-label">RESPONDENTS</div>
          <div class="viz-metric-value" id="stat-total">—</div>
        </div>
        <div class="viz-metric">
          <div class="viz-metric-label">VISITED NEW YORK</div>
          <div class="viz-metric-value" id="stat-visited">—</div>
          <div class="viz-metric-sub" id="stat-visited-sub"></div>
        </div>
        <div class="viz-metric">
          <div class="viz-metric-label">AVG SCORE</div>
          <div class="viz-metric-value" id="stat-avg">—</div>
          <div class="viz-metric-sub" id="stat-range"></div>
        </div>
        <div class="viz-metric">
          <div class="viz-metric-label">SURVEY PERIOD</div>
          <div class="viz-metric-value">37</div>
          <div class="viz-metric-sub">days (May–Jun 2026)</div>
        </div>
      </div>

      <!-- 차원 선호도 차트 -->
      <div class="viz-chart-wrap">
        <div class="viz-chart-label">AESTHETIC DIMENSION PREFERENCES</div>
        <div class="viz-legend">
          <span class="viz-legend-item">
            <span class="viz-legend-dot" style="background:#e24d3a;"></span>Option A
          </span>
          <span class="viz-legend-item">
            <span class="viz-legend-dot" style="background:#d6cfc9;"></span>Option B
          </span>
        </div>
        <div style="position: relative; width: 100%; height: 280px;">
          <canvas id="dimChart" role="img" aria-label="Horizontal stacked bar chart showing aesthetic dimension preferences across 7 dimensions. Refined, Freedom, and Global are dominant choices.">Refined ~82%, Freedom ~61%, Global ~61%, Futuristic ~54%, Closed ~54%, Intimate ~54%, Deliberate ~54%.</canvas>
        </div>
      </div>

      <!-- 하단 두 개 차트 -->
      <div class="viz-two-col">
        <div class="viz-chart-wrap">
          <div class="viz-chart-label">SCORE DISTRIBUTION</div>
          <div style="position: relative; width: 100%; height: 200px;">
            <canvas id="scoreChart" role="img" aria-label="Bar chart of score distribution. Most scores fall between 10 and 16.">Score distribution: most respondents scored between 10 and 16.</canvas>
          </div>
        </div>
        <div class="viz-chart-wrap">
          <div class="viz-chart-label">VISITORS VS NON-VISITORS — AVG SCORE</div>
          <div style="position: relative; width: 100%; height: 200px;">
            <canvas id="visitChart" role="img" aria-label="Bar chart comparing average scores of New York visitors versus non-visitors.">Visitors average slightly higher than non-visitors.</canvas>
          </div>
        </div>
      </div>

      <!-- Chart.js -->
      <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
