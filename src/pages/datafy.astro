          {score:10,ny:'No',answers:['Closed','Refined','Intimate','Futuristic','Incidental','Local','Freedom','Intimate','Local','Opened','Intimate','Nostalgic','Deliberate','Local','Freedom','Raw','Futuristic','Incidental','Global','Order','Opened','Deliberate','Freedom','Closed','Raw','Anonymous','Nostalgic','Opened']},
          {score:14,ny:'No',answers:['Closed','Refined','Intimate','Nostalgic','Deliberate','Global','Order','Intimate','Local','Closed','Anonymous','Nostalgic','Deliberate','Local','Freedom','Refined','Futuristic','Deliberate','Local','Freedom','Opened','Incidental','Freedom','Closed','Refined','Intimate','Futuristic','Opened']},
          {score:13,ny:'No',answers:['Opened','Refined','Anonymous','Futuristic','Incidental','Global','Order','Intimate','Local','Opened','Anonymous','Nostalgic','Incidental','Global','Freedom','Refined','Futuristic','Deliberate','Global','Freedom','Opened','Incidental','Freedom','Opened','Raw','Anonymous','Futuristic','Opened']},
          {score:7,ny:'Yes',answers:['Closed','Refined','Intimate','Nostalgic','Incidental','Local','Freedom','Anonymous','Local','Opened','Anonymous','Nostalgic','Deliberate','Local','Freedom','Refined','Nostalgic','Deliberate','Local','Freedom','Opened','Incidental','Freedom','Opened','Raw','Intimate','Nostalgic','Opened']},
          {score:9,ny:'Yes',answers:['Closed','Refined','Intimate','Nostalgic','Deliberate','Global','Freedom','Intimate','Local','Opened','Anonymous','Nostalgic','Incidental','Local','Freedom','Refined','Futuristic','Incidental','Global','Freedom','Opened','Incidental','Freedom','Opened','Raw','Intimate','Futuristic','Opened']},
          {score:14,ny:'No',answers:['Closed','Refined','Intimate','Nostalgic','Deliberate','Local','Freedom','Intimate','Local','Closed','Anonymous','Nostalgic','Incidental','Global','Freedom','Refined','Nostalgic','Deliberate','Global','Freedom','Opened','Incidental','Order','Closed','Raw','Anonymous','Futuristic','Closed']},
          {score:14,ny:'No',answers:['Closed','Refined','Intimate','Futuristic','Deliberate','Local','Order','Anonymous','Global','Closed','Intimate','Nostalgic','Incidental','Global','Freedom','Refined','Nostalgic','Deliberate','Local','Freedom','Opened','Incidental','Order','Closed','Raw','Anonymous','Nostalgic','Opened']},
          {score:14,ny:'Yes',answers:['Closed','Refined','Intimate','Futuristic','Deliberate','Global','Freedom','Anonymous','Local','Opened','Anonymous','Nostalgic','Incidental','Global','Freedom','Refined','Nostalgic','Incidental','Global','Freedom','Opened','Incidental','Order','Closed','Raw','Anonymous','Nostalgic','Closed']},
        ];

        // 요약 수치 자동 계산
        const total = RAW_DATA.length;
        const visited = RAW_DATA.filter(r => r.ny === 'Yes').length;
        const allScores = RAW_DATA.map(r => r.score);
        const avgScore = (allScores.reduce((a,b) => a+b, 0) / total).toFixed(1);
        const minScore = Math.min(...allScores);
        const maxScore = Math.max(...allScores);
        document.getElementById('stat-total').textContent = total;
        document.getElementById('stat-visited').textContent = Math.round(visited/total*100) + '%';
        document.getElementById('stat-visited-sub').textContent = `${visited} of ${total}`;
        document.getElementById('stat-avg').textContent = avgScore;
        document.getElementById('stat-range').textContent = `Range: ${minScore}–${maxScore}`;

        const DIMS = [
          {label:'Closed / Opened',   a:'Closed',     b:'Opened',     idx:[0,20]},
          {label:'Refined / Raw',     a:'Refined',    b:'Raw',        idx:[1,24]},
          {label:'Anonymous / Intimate', a:'Anonymous', b:'Intimate', idx:[2,7,10,25]},
          {label:'Futuristic / Nostalgic', a:'Futuristic', b:'Nostalgic', idx:[3,11,16,26]},
          {label:'Deliberate / Incidental', a:'Deliberate', b:'Incidental', idx:[4,12,17,21]},
          {label:'Global / Local',    a:'Global',     b:'Local',      idx:[5,8,13,18]},
          {label:'Order / Freedom',   a:'Order',      b:'Freedom',    idx:[6,9,14,19,22]},
        ];

        const dimPcts = DIMS.map(d => {
          let aCount = 0, total = 0;
          RAW_DATA.forEach(r => {
            d.idx.forEach(i => { total++; if (r.answers[i] === d.a) aCount++; });
          });
          return Math.round(aCount / total * 100);
        });

        const BROWN   = '#1c1412';
        const ORANGE  = '#e24d3a';
        const GRAY    = '#5c524f';
        const LIGHT   = '#d6cfc9';
        const GRID    = 'rgba(28,20,18,0.08)';

        // 차원 선호도 차트
        new Chart(document.getElementById('dimChart'), {
          type: 'bar',
          data: {
            labels: DIMS.map(d => d.label),
            datasets: [
              {
                label: 'Option A',
                data: dimPcts,
                backgroundColor: ORANGE,
                borderRadius: 4,
                borderSkipped: false,
              },
              {
                label: 'Option B',
                data: dimPcts.map(v => 100 - v),
                backgroundColor: LIGHT,
                borderRadius: 4,
                borderSkipped: false,
              },
            ]
          },
          options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: { callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.raw}%` } }
            },
            scales: {
              x: {
                stacked: true,
                max: 100,
                ticks: { color: GRAY, font: { size: 11 }, callback: v => v + '%' },
                grid: { color: GRID }
              },
              y: {
                stacked: true,
                ticks: { color: BROWN, font: { size: 12 } },
                grid: { display: false }
              }
            }
          }
        });

        // 스코어 분포 차트
        const bins = [0,0,0,0,0];
        RAW_DATA.forEach(r => {
          if      (r.score <= 10) bins[0]++;
          else if (r.score <= 13) bins[1]++;
          else if (r.score <= 16) bins[2]++;
          else if (r.score <= 20) bins[3]++;
          else                    bins[4]++;
        });

        new Chart(document.getElementById('scoreChart'), {
          type: 'bar',
          data: {
            labels: ['7–10','11–13','14–16','17–20','21–28'],
            datasets: [{
              data: bins,
              backgroundColor: ORANGE,
              borderRadius: 4,
              borderSkipped: false,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { ticks: { color: GRAY, font: { size: 11 } }, grid: { display: false } },
              y: { ticks: { color: GRAY, stepSize: 2 }, grid: { color: GRID } }
            }
          }
        });

        // 방문자 vs 비방문자 차트
        const avg = arr => parseFloat((arr.reduce((a,b) => a+b, 0) / arr.length).toFixed(1));
        const visScores  = RAW_DATA.filter(r => r.ny === 'Yes').map(r => r.score);
        const nonScores  = RAW_DATA.filter(r => r.ny === 'No').map(r => r.score);

        new Chart(document.getElementById('visitChart'), {
          type: 'bar',
          data: {
            labels: [`Visited NY (n=${visScores.length})`, `Not visited (n=${nonScores.length})`],
            datasets: [{
              data: [avg(visScores), avg(nonScores)],
              backgroundColor: [ORANGE, LIGHT],
              borderRadius: 4,
              borderSkipped: false,
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: { display: false },
              tooltip: { callbacks: { label: ctx => ` Avg score: ${ctx.raw}` } }
            },
            scales: {
              x: { ticks: { color: GRAY, font: { size: 11 } }, grid: { display: false } },
              y: { min: 0, max: 20, ticks: { color: GRAY }, grid: { color: GRID } }
            }
          }
        });
      </script>

      <p style="margin-top: 12px; font-size: 0.8rem; color: var(--gray);">
