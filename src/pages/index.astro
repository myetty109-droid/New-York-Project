---
const pageTitle = "NEW YORK TEST";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;1,500&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      :root {
        --canvas: #edebe4;
        --brown:  #1c1412;
        --orange: #e24d3a;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: var(--canvas);
        color: var(--brown);
        font-family: 'Noto Sans KR', sans-serif;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      /* ═══════════════════════════════
         SECTION 1 — HERO
      ═══════════════════════════════ */
      .hero-section {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 0 40px;
        position: relative;
        overflow: hidden;
      }

      /* 좌우 캐릭터 이미지 — 세로 길이에 맞춰 화면을 채우는 기둥으로 설정 */
      .hero-side {
        position: absolute;
        bottom: -2vh;          /* 바닥에 자연스럽게 걸치도록 설정 */
        height: 85vh;          /* 화면 세로 높이의 85% 크기만큼 확보 */
        width: auto;           /* 비율 깨짐 방지 */
        pointer-events: none;
        user-select: none;
        z-index: 1;
      }
      .hero-side img {
        height: 100%;          /* 부모 레벨(.hero-side)의 세로 높이를 꽉 채움 */
        width: auto;           /* 가로 너비는 원본 일러스트 비율 유지 */
        display: block;
        object-fit: contain;
      }
      .hero-side.left  { left: 4vw; }   /* 왼쪽 기둥 위치 */
      .hero-side.right { right: 4vw; }  /* 오른쪽 기둥 위치 */

      /* 가운데 콘텐츠 — 양옆 거대 기둥 일러스트 사이 공간 확보 */
      .hero-content {
        position: relative;
        z-index: 2;
        animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        max-width: 600px;      /* 텍스트 줄바꿈 및 기둥과의 충돌 방지 */
        margin: 0 auto;
      }

      .logo-wrapper { display: flex; justify-content: center; margin-bottom: 24px; }
      .main-logo { max-height: 120px; width: auto; object-fit: contain; }
      .logo-text-fallback {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        letter-spacing: 0.2rem;
        color: #888;
      }

      .main-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.8rem;
        font-weight: 500;
        letter-spacing: 0.2rem;
        color: var(--brown);
        margin-bottom: 16px;
        line-height: 1.2;
      }

      .subtitle {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1.3rem;
        color: #5c524f;
        letter-spacing: 0.05rem;
        margin-bottom: 48px;
      }

      .start-button {
        background: var(--brown);
        color: var(--canvas);
        border: none;
        padding: 16px 56px;
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.15rem;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.3s ease;
      }
      .start-button:hover {
        background-color: var(--orange);
        transform: scale(1.05);
      }

      /* 반응형: 화면이 좁아지면 기둥들이 타이틀 글자와 겹치지 않게 크기/배치 조절 */
      @media (max-width: 1200px) {
        .hero-side { height: 70vh; }
        .main-title { font-size: 3rem; }
      }
      @media (max-width: 768px) {
        .hero-side { height: 50vh; opacity: 0.25; bottom: 0; }
        .hero-side.left  { left: 0; }
        .hero-side.right { right: 0; }
        .main-title { font-size: 2.4rem; }
        .subtitle { font-size: 1.1rem; }
      }

      /* ═══════════════════════════════
         SECTION 2 — ARCHIVE
      ═══════════════════════════════ */
      .content-section {
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 28px 40px 60px;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
      }

      .section-header { margin-bottom: 32px; text-align: center; }
      .section-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 500;
        letter-spacing: 0.2rem;
        margin-bottom: 12px;
      }
      .header-line {
        width: 35px;
        height: 3px;
        background-color: var(--orange);
        margin: 0 auto;
      }

      .scroll-next-btn {
        position: absolute;
        bottom: 20px;
        right: 40px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        color: #9a8e88;
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s;
      }
      .scroll-next-btn:hover { color: var(--orange); }
      .scroll-next-btn::after {
        content: '↓';
        font-size: 0.9rem;
      }

      /* ═══════════════════════════════
         TAG GRID
      ═══════════════════════════════ */
      .tag-grid {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: stretch;
        gap: 24px;
        width: 100%;
      }

      .luggage-tag-container {
        position: relative;
        flex: 1;
        max-width: 300px;
        display: flex;
        flex-direction: column;
        align-items: center;
        cursor: pointer;
        opacity: 0;
        transform-origin: top center;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .luggage-tag-container.tag-drop {
        animation: tagDrop 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      }

      .tag-strap {
        width: 22px;
        height: 32px;
        background-color: var(--brown);
        border-radius: 4px 4px 0 0;
        margin-bottom: -2px;
        z-index: 2;
        position: relative;
      }
      .tag-strap::before {
        content: '';
        position: absolute;
        top: 5px;
        left: 50%;
        transform: translateX(-50%);
        width: 6px;
        height: 6px;
        background: #c8a96e;
        border-radius: 50%;
      }
      .theme-black .tag-strap { background-color: #111; }
      .theme-red   .tag-strap {
        background-color: var(--orange);
        border: 2px solid var(--brown);
        border-bottom: none;
      }
      .theme-red .tag-strap::before { background: #fff4e0; }

      .luggage-tag-body {
        position: relative;
        width: 100%;
        border: 2px solid var(--brown);
        border-radius: 36px 36px 10px 10px;
        padding: 42px 22px 22px 22px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex: 1;
        overflow: hidden;
      }

      .luggage-tag-body::before {
        content: '';
        position: absolute;
        inset: 7px;
        border: 1px dashed rgba(28,20,18,0.18);
        border-radius: 28px 28px 5px 5px;
        pointer-events: none;
      }

      .tag-slot {
        position: absolute;
        top: 13px;
        left: 50%;
        transform: translateX(-50%);
        width: 28px;
        height: 8px;
        background-color: var(--canvas);
        border: 2px solid var(--brown);
        border-radius: 20px;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.15);
      }

      .tag-flight {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.18rem;
        color: rgba(28,20,18,0.3);
        text-align: right;
        margin-bottom: 8px;
      }

      .tag-content { display: flex; flex-direction: column; }
      .luggage-tag-body h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 500;
        margin-bottom: 10px;
        line-height: 1.3;
      }
      .luggage-tag-body p {
        font-size: 0.82rem;
        line-height: 1.55;
        font-weight: 400;
        text-align: left;
        opacity: 0.85;
      }
      .card-link {
        text-decoration: none;
        font-size: 0.8rem;
        letter-spacing: 0.06rem;
        font-weight: 700;
        margin-top: 16px;
        width: max-content;
        padding-bottom: 2px;
        border-bottom: 2px solid currentColor;
        transition: opacity 0.2s;
      }
      .card-link:hover { opacity: 0.7; }

      .theme-beige .luggage-tag-body { background-color: #edebe4; }
      .theme-beige .tag-flight { color: rgba(28,20,18,0.3); }
      .theme-beige h3, .theme-beige p { color: var(--brown); }
      .theme-beige .card-link { color: var(--brown); }
      .theme-beige:hover .luggage-tag-body { box-shadow: 0 16px 32px rgba(28,20,18,0.1); }

      .theme-black .luggage-tag-body { background-color: #111; border-color: #111; }
      .theme-black .luggage-tag-body::before { border-color: rgba(255,255,255,0.12); }
      .theme-black .tag-slot { background-color: var(--canvas); border-color: #333; }
      .theme-black .tag-strap::before { background: #c8a96e; }
      .theme-black .tag-flight { color: rgba(255,255,255,0.25); }
      .theme-black h3 { color: #fff; }
      .theme-black p { color: #bcbcbc; }
      .theme-black .card-link { color: #fff; }
      .theme-black .tag-barcode span { background: #fff; }
      .theme-black:hover .luggage-tag-body { background-color: #000; box-shadow: 0 20px 36px rgba(0,0,0,0.35); }

      .theme-red .luggage-tag-body { background-color: var(--orange); border-color: var(--orange); }
      .theme-red .luggage-tag-body::before { border-color: rgba(255,255,255,0.2); }
      .theme-red .tag-slot { background-color: var(--canvas); border-color: rgba(255,255,255,0.4); }
      .theme-red .tag-flight { color: rgba(255,255,255,0.35); }
      .theme-red h3, .theme-red p, .theme-red .card-link { color: #fff; }
      .theme-red .tag-barcode span { background: #fff; }
      .theme-red:hover .luggage-tag-body { background-color: #d6412e; box-shadow: 0 16px 32px rgba(226,77,58,0.25); }

      /* ═══════════════════════════════
         TAGLINE + QUOTE
      ═══════════════════════════════ */
      .archive-tagline {
        text-align: center;
        margin-bottom: 20px;
        font-size: 0.88rem;
        color: #7a6e68;
        letter-spacing: 0.04rem;
        line-height: 1.7;
        max-width: 600px;
      }

      .archive-quote {
        text-align: center;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid rgba(28,20,18,0.1);
        width: 100%;
        max-width: 560px;
      }
      .archive-quote blockquote {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 0.92rem;
        color: #5c524f;
        line-height: 1.75;
        margin-bottom: 6px;
      }
      .archive-quote cite {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        color: #9a8e88;
      }

      /* ═══════════════════════════════
         AIRPLANE DECORATION
      ═══════════════════════════════ */
      .plane-deco {
        position: absolute;
        pointer-events: none;
        opacity: 0.15;
        font-size: 1.4rem;
        animation: flyPlane 18s linear infinite;
      }
      .plane-deco.p1 { top: 18%; animation-delay: 0s; }
      .plane-deco.p2 { top: 72%; animation-delay: 7s; font-size: 1.1rem; }
      .plane-deco.p3 { top: 44%; animation-delay: 13s; font-size: 1.2rem; }

      @keyframes flyPlane {
        0%   { left: -5%; opacity: 0; }
        5%   { opacity: 0.12; }
        95%  { opacity: 0.12; }
        100% { left: 105%; opacity: 0; }
      }

      .about-section {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 80px 40px;
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
      }

      .about-header { text-align: center; margin-bottom: 48px; }
      .about-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 500;
        letter-spacing: 0.2rem;
        margin-bottom: 12px;
      }
      .about-line {
        width: 35px;
        height: 3px;
        background-color: var(--orange);
        margin: 0 auto;
      }

      .about-body {
        font-size: 0.95rem;
        line-height: 1.95;
        color: #3a3330;
        text-align: left;
        width: 100%;
      }
      .about-body p + p { margin-top: 1.4em; }

      /* ═══════════════════════════════
         ANIMATIONS
      ═══════════════════════════════ */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes tagDrop {
        0%   { opacity: 0; transform: translateY(-60px) rotate(0deg); }
        45%  { opacity: 1; transform: translateY(8px) rotate(3deg); }
        65%  { transform: translateY(-4px) rotate(-2deg); }
        80%  { transform: translateY(2px) rotate(1deg); }
        100% { opacity: 1; transform: translateY(0) rotate(0deg); }
      }

      /* ═══════════════════════════════
         MOBILE
      ═══════════════════════════════ */
      @media (max-width: 768px) {
        .content-section {
          height: auto;
          min-height: 100vh;
          padding: 60px 24px 80px;
        }
        .tag-grid { flex-direction: column; align-items: center; gap: 30px; }
        .luggage-tag-container { width: 100%; max-width: 300px; }
        .main-title { font-size: 2.6rem; }
        .scroll-next-btn { right: 20px; bottom: 20px; }
      }
    </style>
  </head>

  <body>

    <section class="hero-section">

      <div class="hero-side left">
        <img src="/landingpage-left.png" alt="Left Pillar Illustration" />
      </div>

      <div class="hero-content">
        <div class="logo-wrapper">
          <img
            src="/logo.png"
            alt="NY TEST Logo"
            class="main-logo"
            onerror="this.style.display='none'; document.getElementById('logo-fallback').style.display='block';"
          />
          <div id="logo-fallback" class="logo-text-fallback" style="display:none;">[ LOGO ]</div>
        </div>
        <h1 class="main-title">{pageTitle}</h1>
        <p class="subtitle">Look New, Look Again</p>
        <button id="start-btn" class="start-button">FIND OUT</button>
      </div>

      <div class="hero-side right">
        <img src="/landingpage-right.png" alt="Right Pillar Illustration" />
      </div>

    </section>

    <section id="content-section" class="content-section">

      <span class="plane-deco p1">✈</span>
      <span class="plane-deco p2">✈</span>
      <span class="plane-deco p3">✈</span>

      <div class="section-header">
        <h2>PROJECT ARCHIVES</h2>
        <div class="header-line"></div>
      </div>

      <p class="archive-tagline">
        Take the test to discover your observer type, explore the photo archive,<br>
        and lose yourself in a game set in the streets of New York.
      </p>

      <div class="tag-grid">

        <div class="luggage-tag-container theme-beige" onclick="location.href='/datafy'">
          <div class="tag-strap"></div>
          <div class="luggage-tag-body">
            <div class="tag-slot"></div>
            <div class="tag-flight">NYC · 01</div>
            <div class="tag-content">
              <h3>New York Test</h3>
              <p>Take the test and find out what kind of city observer you are through New York!</p>
            </div>
            <a href="/datafy" class="card-link">Take Survey →</a>
          </div>
        </div>

        <div class="luggage-tag-container theme-black" onclick="location.href='/aesthetics'">
          <div class="tag-strap"></div>
          <div class="luggage-tag-body">
            <div class="tag-slot"></div>
            <div class="tag-flight">NYC · 02</div>
            <div class="tag-content">
              <h3>The Pigeon and the Unseen</h3>
              <p>Check out our photo archive and vote for your best pick!</p>
            </div>
            <a href="/aesthetics" class="card-link">Open Gallery →</a>
          </div>
        </div>

        <div class="luggage-tag-container theme-red" onclick="location.href='/narrative'">
          <div class="tag-strap"></div>
          <div class="luggage-tag-body">
            <div class="tag-slot"></div>
            <div class="tag-flight">NYC · 03</div>
            <div class="tag-content">
              <h3>That Pigeon Took My Phone!</h3>
              <p>Can you find your lost phone in the middle of Manhattan? Try our interactive Twine game.</p>
            </div>
            <a href="/narrative" class="card-link">Play Game →</a>
          </div>
        </div>

      </div>

      <div class="archive-quote">
        <blockquote>
          "For the perfect flâneur, for the passionate spectator, it is an immense joy to set up house in the heart of the multitude, amid the ebb and flow of movement, in the midst of the fugitive and the infinite."
        </blockquote>
        <cite>— Charles Baudelaire, The Painter of Modern Life, 1863</cite>
      </div>

      <button class="scroll-next-btn" id="about-btn">ABOUT THIS PROJECT</button>
    </section>

    <section id="about-section" class="about-section">
      <div class="about-header">
        <h2>ABOUT</h2>
        <div class="about-line"></div>
      </div>

      <div class="about-body">
        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 500; margin-bottom: 20px;">Methodological Reflection: The New York Test</h3>

        <p>
          This project is neither an informational storage nor a passive exhibition of a great dead writer’s legacy displayed with honor. It does not hand the user a predetermined answer on the first page of the web experience. Instead, it operates as an intentional, dynamic medium, a giant void much like the urban grid itself, designed to shift something within the observer. The core question animating this digital inquiry is not what New York is, but rather how the word New York changes inside the users after interacting with this website. This internal transformation serves as the ultimate culmination of the project, the true icing on the cake.
        </p>

        <p>
          To explore this transformation, the project repurposes a single, unified archive of personal photographs captured on the streets of New York, acting as an aesthetic amplifier. It channels a singular visual reality into three distinct conceptual lenses: a visual keyword recognition test, a themed photographic archive, and an interactive fiction game. By shifting the mode of curation, the project demonstrates how the cityscape functions as a blank canvas, fracturing and reforming based entirely on the framework through which it is perceived.
        </p>

        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 500; margin-top: 40px; margin-bottom: 16px; color: var(--orange);">1. Process: Curation, Filtering, and Methodological Decisions</h3>

        <p>
          The foundation of this digital inquiry rests on a methodology that translates physical street observation into structured digital data. The raw data consisted of several hundred street photographs taken during a period of open-ended walking through Manhattan and its outer boroughs. To transform this unorganized collection into a functional dataset for the visual survey, the data underwent a strict process of qualitative cleaning and pair-matching.
        </p>

        <p>
          The first major decision involved filtering out explicit temporal and geographical markers. Images featuring obvious commercial landmarks, recognizable advertisements, or explicit street signs were systematically removed. This step ensured that participants would respond to the underlying textures, forms, and atmospheric qualities of the city rather than their preconceived geographical knowledge or memories of specific tourist destinations.
        </p>

        <p>
          The remaining photographs were then categorized into binary pairs to establish a series of twenty-eight visual questions. Each pair was curated to encode a specific aesthetic or philosophical tension. The cleaning process here required balancing the visual weight of the images. For instance, when testing the tension between raw and refined urban spaces, the photographs were balanced for lighting, color saturation, and geometric composition. This careful alignment ensured that the user’s choice would be driven by the conceptual dichotomy rather than accidental visual noise, such as one image being brighter or more colorful than its partner.
        </p>

        <p>
          For the second lens, the photographic archive, the images were cleaned and grouped into three distinct thematic exhibitions: Hello, Gorgeous!, No Way Home, and The Eye of a Tornado. The primary decision here was to curate based on spatial fragments rather than panoramic views. The focus was deliberately shifted toward architectural gaps, the precise angle of afternoon light striking a brick facade, or the solitary shadow of a fire escape cast across a doorway. This structural ordering was designed to reflect the classic methodology of flânerie, converting passive snapshots into a highly deliberate digital text.
        </p>

        <p>
          Finally, the same asset pool was adapted for the third lens, an interactive fiction piece built in Twine. The primary data decision involved mapping specific image assets to branching narrative choices. The photographs were stripped of their original real-world contexts and embedded into an absurd, fictionalized Manhattan maze where a pigeon has stolen the user's phone. This translation of static image data into interactive narrative nodes required a complete restructuring of how the files were cataloged, shifting their function from passive aesthetic objects to active choices within a digital environment.
        </p>

        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 500; margin-top: 40px; margin-bottom: 16px; color: var(--orange);">2. Limitations: The Boundaries of the Digital Dataset</h3>

        <p>
          Every digital dataset carries inherent absences, and recognizing what is missing is essential to understanding the boundaries of this methodology. The most prominent limitation of the current dataset is its reliance on a singular, subjective eye. Because all the photographs were taken by a single individual, the archive inherently lacks a pluralistic foundation. It captures one specific walking route, one particular set of historical moments, and one individual's spontaneous attention. The archive cannot represent the vast, contradictory totalities of New York, nor can it account for the sensory experiences that escape visual capture, such as sound, smell, and tactile density.
        </p>

        <p>
          Furthermore, the analytical tools utilized in this project possess distinct operational constraints. While Gephi is highly effective at rendering structural relationships between aesthetic preferences, the tool cannot interpret the psychological depth behind a user's choice. The network analysis software processes data mathematically, treating an instinctual, split-second click with the same statistical weight as a deeply considered philosophical decision. It maps the proximity between selections, but it cannot explain why a user felt drawn to a specific image pair or what personal memories informed that attraction.
        </p>

        <p>
          In the interactive fiction component, the Twine framework enforces a rigid, algorithmic logic that runs counter to the true freedom of physical walking. In the physical streets of Manhattan, a walker can choose an infinite number of paths, pause indefinitely, or change their pace at will. The digital tool, by contrast, restricts the user to binary or tertiary branching paths. The digital flâneur in this game is ultimately trapped within a pre-scripted labyrinth of code, demonstrating that while digital tools can simulate urban complexity, they inevitably reduce the radical spontaneity of the physical world into a structured set of electronic parameters.
        </p>

        <h3 style="font-family: 'Playfair Display', serif; font-size: 1.2rem; font-weight: 500; margin-top: 40px; margin-bottom: 16px; color: var(--orange);">3. The Digital Difference: Network Analysis and Collective Vision</h3>

        <p>
          Despite these limitations, the transition from traditional urban observation to digital inquiry reveals structural insights that reading or walking alone could never uncover. This digital difference is most clearly illustrated in the integration of Charles Baudelaire’s aesthetic theories with modern network visualization. Baudelaire posited that beauty is a dual entity, an intricate combination of an absolute, unchanging value, which he called the eternal soul, and a fleeting, culturally specific element, termed the transient body.
        </p>

        <p>
          Traditional observation allows an individual to notice these elements in isolation. However, by subjecting the visual survey results to force-directed graph algorithms in Gephi, the digital inquiry makes the invisible architecture of collective taste visible. For example, a traditional close reading of individual survey responses might suggest that aesthetic choices are entirely random, highly subjective, and chaotic. Yet, when the data is visualized as a network graph, a striking phenomenon occurs. The random, fleeting choices of hundreds of disparate users begin to cluster together, revealing eleventh distinct observer types.
        </p>

        <p>
          I never fully grasped the structured nature of urban aesthetics until I visualized the network. The graph revealed that a preference for raw, unfiltered environments directly correlates with a specific appreciation for transit and anonymity, clustering users into distinct profiles like the Grand Central Clock or the Chinatown Unicorn. This digital grouping proves that what Baudelaire called the transient body of beauty is not a chaotic mess of individual whims. Instead, it possesses an underlying structural logic. The network visualization uncovers a shared, collective vision, demonstrating that the modern city shapes the minds of its observers in predictable, repeating patterns.
        </p>

        <p>
          Similarly, the digital format of the photographic archive introduces a layer of data that traditional gallery exhibitions cannot replicate. In a physical gallery, a visitor's pause before a photograph remains a private, invisible event. In this digital space, every click that registers a heart on an image accumulates into a collective pool of behavioral data. The website transforms the individual act of looking into a shared archive of human attention. By analyzing which specific gaps or shadows hold the collective gaze across different user backgrounds, the digital inquiry identifies the exact points where the transient image touches something universal.
        </p>

        <p>
          Ultimately, the digital inquiry fulfills Baudelaire’s demand that the artist become a passionate spectator who extracts the eternal from the refuge of the momentary. By splintering a single geographic source into a quantitative survey, a qualitative archive, and a playful interactive game, the project acts as a powerful amplifier for the theory of flânerie. It forces the digital interface to do what a physical book or a simple photo gallery cannot, it maps the invisible currents of human perception, revealing how the modern grid redraws itself within the minds of those who wander through it.
        </p>
      </div>
    </section>

    <script>
      // ① FIND OUT 버튼 → 아카이브 섹션
      const startBtn = document.getElementById('start-btn');
      const contentSection = document.getElementById('content-section');
      if (startBtn && contentSection) {
        startBtn.addEventListener('click', () => {
          contentSection.scrollIntoView({ behavior: 'smooth' });
        });
      }

      // ② ABOUT 버튼 → 설명 섹션
      const aboutBtn = document.getElementById('about-btn');
      const aboutSection = document.getElementById('about-section');
      if (aboutBtn && aboutSection) {
        aboutBtn.addEventListener('click', () => {
          aboutSection.scrollIntoView({ behavior: 'smooth' });
        });
      }

      // ③ 카드 등장 애니메이션 (IntersectionObserver)
      const tagContainers = document.querySelectorAll('.luggage-tag-container');
      let hasAnimated = false;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !hasAnimated) {
              hasAnimated = true;
              tagContainers.forEach((tag, index) => {
                setTimeout(() => {
                  tag.classList.add('tag-drop');
                }, index * 180);
              });
              observer.disconnect();
            }
          });
        },
        { threshold: 0.3 }
      );

      if (contentSection) {
        observer.observe(contentSection);
      }
    </script>
  </body>
</html>