---
const pageTitle = "NEW YORK TEST";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;1,500&family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">

    <style>
      :root {
        --canvas: #edebe4;
        --brown:  #1c1412;
        --orange: #e24d3a;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        background-color: var(--canvas);
        color: var(--brown);
        font-family: 'Noto Sans KR', sans-serif;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      /* ═══════════════════════════════
         SECTION 1 — HERO
      ═══════════════════════════════ */
      .hero-section {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 20px;
        position: relative;
        overflow: hidden;
      }

      /* 좌우 캐릭터 이미지 — 화면을 채우는 나무처럼 */
      .hero-side {
        position: absolute;
        bottom: 0;
        width: 30%;
        max-width: 500px;
        pointer-events: none;
        user-select: none;
      }
      .hero-side img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
      }
      .hero-side.left  { left: 0; }
      .hero-side.right { right: 0; }

      /* 가운데 콘텐츠 — 양쪽 이미지 너비만큼 여백 확보 */
      .hero-content {
        position: relative;
        z-index: 2;
        animation: fadeIn 1.2s cubic-bezier(0.16, 1, 0.3, 1);
        padding: 0 34%;
      }

      .logo-wrapper { display: flex; justify-content: center; margin-bottom: 24px; }
      .main-logo { max-height: 120px; width: auto; object-fit: contain; }
      .logo-text-fallback {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        letter-spacing: 0.2rem;
        color: #888;
      }

      .main-title {
        font-family: 'Playfair Display', serif;
        font-size: 3.8rem;
        font-weight: 500;
        letter-spacing: 0.2rem;
        color: var(--brown);
        margin-bottom: 16px;
      }

      .subtitle {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 1.3rem;
        color: #5c524f;
        letter-spacing: 0.05rem;
        margin-bottom: 48px;
      }

      .start-button {
        background: var(--brown);
        color: var(--canvas);
        border: none;
        padding: 16px 56px;
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 0.15rem;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.3s ease;
      }
      .start-button:hover {
        background-color: var(--orange);
        transform: scale(1.05);
      }

      @media (max-width: 768px) {
        .hero-side { width: 44%; }
        .hero-content { padding: 0 8%; }
        .main-title { font-size: 2.2rem; }
        .subtitle { font-size: 1rem; }
      }
      @media (max-width: 480px) {
        .hero-side { width: 50%; opacity: 0.35; }
        .hero-content { padding: 0; }
      }

      /* ═══════════════════════════════
         SECTION 2 — ARCHIVE
      ═══════════════════════════════ */
      .content-section {
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 28px 40px 60px;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
      }

      .section-header { margin-bottom: 32px; text-align: center; }
      .section-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 500;
        letter-spacing: 0.2rem;
        margin-bottom: 12px;
      }
      .header-line {
        width: 35px;
        height: 3px;
        background-color: var(--orange);
        margin: 0 auto;
      }

      /* 우하단 "다음 섹션" 버튼 */
      .scroll-next-btn {
        position: absolute;
        bottom: 20px;
        right: 40px;
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        color: #9a8e88;
        background: none;
        border: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: color 0.2s;
      }
      .scroll-next-btn:hover { color: var(--orange); }
      .scroll-next-btn::after {
        content: '↓';
        font-size: 0.9rem;
      }

      /* ═══════════════════════════════
         TAG GRID
      ═══════════════════════════════ */
      .tag-grid {
        display: flex;
        flex-direction: row;
        justify-content: center;
        align-items: stretch;
        gap: 24px;
        width: 100%;
      }

      /* ── 러기지 태그 컨테이너 ── */
      .luggage-tag-container {
        position: relative;
        flex: 1;
        max-width: 300px;
        display: flex;
        flex-direction: column;
        align-items: center;
        cursor: pointer;
        opacity: 0;
        transform-origin: top center;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .luggage-tag-container.tag-drop {
        animation: tagDrop 0.9s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
      }

      /* ── 스트랩 (가죽끈) ── */
      .tag-strap {
        width: 22px;
        height: 32px;
        background-color: var(--brown);
        border-radius: 4px 4px 0 0;
        margin-bottom: -2px;
        z-index: 2;
        position: relative;
      }
      .tag-strap::before {
        content: '';
        position: absolute;
        top: 5px;
        left: 50%;
        transform: translateX(-50%);
        width: 6px;
        height: 6px;
        background: #c8a96e;
        border-radius: 50%;
      }
      .theme-black .tag-strap { background-color: #111; }
      .theme-red   .tag-strap {
        background-color: var(--orange);
        border: 2px solid var(--brown);
        border-bottom: none;
      }
      .theme-red .tag-strap::before { background: #fff4e0; }

      /* ── 태그 본체 ── */
      .luggage-tag-body {
        position: relative;
        width: 100%;
        border: 2px solid var(--brown);
        border-radius: 36px 36px 10px 10px;
        padding: 42px 22px 22px 22px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        flex: 1;
        overflow: hidden;
      }

      /* 내부 점선 테두리 */
      .luggage-tag-body::before {
        content: '';
        position: absolute;
        inset: 7px;
        border: 1px dashed rgba(28,20,18,0.18);
        border-radius: 28px 28px 5px 5px;
        pointer-events: none;
      }

      /* 타원형 알구멍 슬롯 */
      .tag-slot {
        position: absolute;
        top: 13px;
        left: 50%;
        transform: translateX(-50%);
        width: 28px;
        height: 8px;
        background-color: var(--canvas);
        border: 2px solid var(--brown);
        border-radius: 20px;
        box-shadow: inset 0 1px 2px rgba(0,0,0,0.15);
      }

      /* 항공편 코드 */
      .tag-flight {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.18rem;
        color: rgba(28,20,18,0.3);
        text-align: right;
        margin-bottom: 8px;
      }

      .tag-content { display: flex; flex-direction: column; }
      .luggage-tag-body h3 {
        font-family: 'Playfair Display', serif;
        font-size: 1.15rem;
        font-weight: 500;
        margin-bottom: 10px;
        line-height: 1.3;
      }
      .luggage-tag-body p {
        font-size: 0.82rem;
        line-height: 1.55;
        font-weight: 400;
        text-align: left;
        opacity: 0.85;
      }
      .card-link {
        text-decoration: none;
        font-size: 0.8rem;
        letter-spacing: 0.06rem;
        font-weight: 700;
        margin-top: 16px;
        width: max-content;
        padding-bottom: 2px;
        border-bottom: 2px solid currentColor;
        transition: opacity 0.2s;
      }
      .card-link:hover { opacity: 0.7; }

      /* ── 테마: 베이지 ── */
      .theme-beige .luggage-tag-body { background-color: #edebe4; }
      .theme-beige .tag-flight { color: rgba(28,20,18,0.3); }
      .theme-beige h3, .theme-beige p { color: var(--brown); }
      .theme-beige .card-link { color: var(--brown); }
      .theme-beige:hover .luggage-tag-body { box-shadow: 0 16px 32px rgba(28,20,18,0.1); }

      /* ── 테마: 블랙 ── */
      .theme-black .luggage-tag-body { background-color: #111; border-color: #111; }
      .theme-black .luggage-tag-body::before { border-color: rgba(255,255,255,0.12); }
      .theme-black .tag-slot { background-color: var(--canvas); border-color: #333; }
      .theme-black .tag-strap::before { background: #c8a96e; }
      .theme-black .tag-flight { color: rgba(255,255,255,0.25); }
      .theme-black h3 { color: #fff; }
      .theme-black p { color: #bcbcbc; }
      .theme-black .card-link { color: #fff; }
      .theme-black .tag-barcode span { background: #fff; }
      .theme-black:hover .luggage-tag-body { background-color: #000; box-shadow: 0 20px 36px rgba(0,0,0,0.35); }

      /* ── 테마: 레드 ── */
      .theme-red .luggage-tag-body { background-color: var(--orange); border-color: var(--orange); }
      .theme-red .luggage-tag-body::before { border-color: rgba(255,255,255,0.2); }
      .theme-red .tag-slot { background-color: var(--canvas); border-color: rgba(255,255,255,0.4); }
      .theme-red .tag-flight { color: rgba(255,255,255,0.35); }
      .theme-red h3, .theme-red p, .theme-red .card-link { color: #fff; }
      .theme-red .tag-barcode span { background: #fff; }
      .theme-red:hover .luggage-tag-body { background-color: #d6412e; box-shadow: 0 16px 32px rgba(226,77,58,0.25); }

      /* ═══════════════════════════════
         TAGLINE + QUOTE
      ═══════════════════════════════ */
      .archive-tagline {
        text-align: center;
        margin-bottom: 20px;
        font-size: 0.88rem;
        color: #7a6e68;
        letter-spacing: 0.04rem;
        line-height: 1.7;
        max-width: 600px;
      }

      .archive-quote {
        text-align: center;
        margin-top: 28px;
        padding-top: 20px;
        border-top: 1px solid rgba(28,20,18,0.1);
        width: 100%;
        max-width: 560px;
      }
      .archive-quote blockquote {
        font-family: 'Playfair Display', serif;
        font-style: italic;
        font-size: 0.92rem;
        color: #5c524f;
        line-height: 1.75;
        margin-bottom: 6px;
      }
      .archive-quote cite {
        font-size: 0.72rem;
        font-weight: 700;
        letter-spacing: 0.1rem;
        color: #9a8e88;
      }

      /* ═══════════════════════════════
         AIRPLANE DECORATION
      ═══════════════════════════════ */
      .plane-deco {
        position: absolute;
        pointer-events: none;
        opacity: 0.15;
        font-size: 1.4rem;
        animation: flyPlane 18s linear infinite;
      }
      .plane-deco.p1 { top: 18%; animation-delay: 0s; }
      .plane-deco.p2 { top: 72%; animation-delay: 7s; font-size: 1.1rem; }
      .plane-deco.p3 { top: 44%; animation-delay: 13s; font-size: 1.2rem; }

      @keyframes flyPlane {
        0%   { left: -5%; opacity: 0; }
        5%   { opacity: 0.12; }
        95%  { opacity: 0.12; }
        100% { left: 105%; opacity: 0; }
      }
      .about-section {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 80px 40px;
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
      }

      .about-header { text-align: center; margin-bottom: 48px; }
      .about-header h2 {
        font-family: 'Playfair Display', serif;
        font-size: 1.6rem;
        font-weight: 500;
        letter-spacing: 0.2rem;
        margin-bottom: 12px;
      }
      .about-line {
        width: 35px;
        height: 3px;
        background-color: var(--orange);
        margin: 0 auto;
      }

      /* 텍스트를 붙여넣는 공간 */
      .about-body {
        font-size: 0.95rem;
        line-height: 1.95;
        color: #3a3330;
        text-align: left;
        width: 100%;
      }
      /* 단락 사이 여백 */
      .about-body p + p { margin-top: 1.4em; }

      /* ═══════════════════════════════
         ANIMATIONS
      ═══════════════════════════════ */
      @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      @keyframes tagDrop {
        0%   { opacity: 0; transform: translateY(-60px) rotate(0deg); }
        45%  { opacity: 1; transform: translateY(8px) rotate(3deg); }
        65%  { transform: translateY(-4px) rotate(-2deg); }
        80%  { transform: translateY(2px) rotate(1deg); }
        100% { opacity: 1; transform: translateY(0) rotate(0deg); }
      }

      /* ═══════════════════════════════
         MOBILE
      ═══════════════════════════════ */
      @media (max-width: 768px) {
        .content-section {
          height: auto;
          min-height: 100vh;
          padding: 60px 24px 80px;
        }
        .tag-grid { flex-direction: column; align-items: center; gap: 30px; }
        .luggage-tag-container { width: 100%; max-width: 300px; }
        .main-title { font-size: 2.6rem; }
        .scroll-next-btn { right: 20px; bottom: 20px; }
      }
    </style>
  </head>

  <body>

    <!-- ① HERO -->
    <section class="hero-section">

      <!-- 왼쪽 캐릭터 -->
      <div class="hero-side left">
        <img src="/landingpage-left.png" alt="" />
      </div>

      <!-- 가운데 콘텐츠 -->
      <div class="hero-content">
        <div class="logo-wrapper">
          <img
            src="/logo.png"
            alt="NY TEST Logo"
            class="main-logo"
            onerror="this.style.display='none'; document.getElementById('logo-fallback').style.display='block';"
          />
          <div id="logo-fallback" class="logo-text-fallback" style="display:none;">[ LOGO ]</div>
        </div>
        <h1 class="main-title">{pageTitle}</h1>
        <p class="subtitle">Look New, Look Again</p>
        <button id="start-btn" class="start-button">FIND OUT</button>
      </div>

      <!-- 오른쪽 캐릭터 -->
      <div class="hero-side right">
        <img src="/landingpage-right.png" alt="" />
      </div>

    </section>

    <!-- ② ARCHIVE -->
    <section id="content-section" class="content-section">

      <!-- 비행기 장식 -->
      <span class="plane-deco p1">✈</span>
      <span class="plane-deco p2">✈</span>
      <span class="plane-deco p3">✈</span>

      <div class="section-header">
        <h2>PROJECT ARCHIVES</h2>
        <div class="header-line"></div>
      </div>

      <!-- 태그라인 -->
      <p class="archive-tagline">
        Take the test to discover your observer type, explore the photo archive,<br>
        and lose yourself in a game set in the streets of New York.
      </p>

      <div class="tag-grid">

        <!-- TAG 1 — 베이지 -->
        <div class="luggage-tag-container theme-beige" onclick="location.href='/datafy'">
          <div class="tag-strap"></div>
          <div class="luggage-tag-body">
            <div class="tag-slot"></div>
            <div class="tag-flight">NYC · 01</div>
            <div class="tag-content">
              <h3>New York Test</h3>
              <p>Take the test and find out what kind of city observer you are through New York!</p>
            </div>
            <a href="/datafy" class="card-link">Take Survey →</a>
          </div>
        </div>

        <!-- TAG 2 — 블랙 -->
        <div class="luggage-tag-container theme-black" onclick="location.href='/aesthetics'">
          <div class="tag-strap"></div>
          <div class="luggage-tag-body">
            <div class="tag-slot"></div>
            <div class="tag-flight">NYC · 02</div>
            <div class="tag-content">
              <h3>The Pigeon and the Unseen</h3>
              <p>Check out our photo archive and vote for your best pick!</p>
            </div>
            <a href="/aesthetics" class="card-link">Open Gallery →</a>
          </div>
        </div>

        <!-- TAG 3 — 레드 -->
        <div class="luggage-tag-container theme-red" onclick="location.href='/narrative'">
          <div class="tag-strap"></div>
          <div class="luggage-tag-body">
            <div class="tag-slot"></div>
            <div class="tag-flight">NYC · 03</div>
            <div class="tag-content">
              <h3>That Pigeon Took My Phone!</h3>
              <p>Can you find your lost phone in the middle of Manhattan? Try our interactive Twine game.</p>
            </div>
            <a href="/narrative" class="card-link">Play Game →</a>
          </div>
        </div>

      </div>

      <!-- 보들레르 명언 -->
      <div class="archive-quote">
        <blockquote>
          "For the perfect flâneur, for the passionate spectator, it is an immense joy to set up house in the heart of the multitude, amid the ebb and flow of movement, in the midst of the fugitive and the infinite."
        </blockquote>
        <cite>— Charles Baudelaire, The Painter of Modern Life, 1863</cite>
      </div>

      <!-- 우하단 다음 섹션 이동 버튼 -->
      <button class="scroll-next-btn" id="about-btn">ABOUT THIS PROJECT</button>
    </section>

    <!-- ③ ABOUT -->
    <section id="about-section" class="about-section">
      <div class="about-header">
        <h2>ABOUT</h2>
        <div class="about-line"></div>
      </div>

      <!-- ✏️ 여기에 설명 텍스트를 붙여넣으세요 -->
      <div class="about-body">
        <p>
  The New York Test is neither a standard informational storage nor a passive digital museum built to exhibit historical archives with detached honor. It does not hand the visitor a predetermined conclusion or a curated definition of a city upon entering the first page of the web experience. Instead, this platform operates as an intentional, dynamic medium, a structured void much like the physical urban grid itself, designed to catalyze a shift within the observer. The central inquiry animating this digital project does not ask what New York is, but rather focuses on an entirely internal outcome: how does the word New York change inside the user after navigating this interface? This personal transformation represents the ultimate destination and the true icing on the cake.
</p>

<p>
  To investigate this perceptual shift, the project re-contextualizes a single, comprehensive archive of street photographs captured during open-ended walks through Manhattan and its surrounding boroughs. Serving as an aesthetic amplifier, the website funnels a singular raw reality into three separate conceptual lenses, a visual keyword recognition survey, a themed digital archive, and an interactive fiction game. By fracturing the same photographic assets across these distinct pathways, the project demonstrates how the urban landscape serves as an ambiguous text, shifting and reforming based completely on the framework through which it is perceived.
</p>

<p>
  The first lens, a twenty-eight-question visual survey, draws directly from Charles Baudelaire’s theory of dual aesthetics. Baudelaire defined beauty as a product of two forces, a transient body that reflects the passing trends, styles, and fashions of an era, and an eternal soul containing an absolute value. By forcing participants to make instinctual, split-second choices between contrasting pairs of images, the survey captures the immediate, subconscious reactions of the observer to the city’s surfaces. When these individual selections are mapped through force-directed network analysis algorithms, they reveal a structured underlying logic. Fleeting individual whims coalesce into eleven distinct observer types, demonstrating that our aesthetic responses to the modern grid are deeply patterned rather than chaotic.
</p>

<p>
  The second lens transforms the user into a traditional practitioner of flânerie through a curated photographic archive. Avoiding major landmarks and typical postcard views, the imagery isolates the overlooked gaps of the built environment, the quiet spaces between structures, the slant of afternoon light against aged brick, and the geometric shadows of fire escapes. Visitors are invited to pause and mark the visuals that cause a moment of internal arrest. The collective accumulation of these responses creates a secondary layer of data, transforming a private gallery experience into a shared, digital repository of human attention. This collaborative tracking maps the exact coordinates where the transient modern image connects with the eternal soul of collective resonance.
</p>

<p>
  The final lens introduces an element of deliberate artifice through an interactive fiction piece where a stray pigeon steals the user's phone in the middle of Manhattan. In an era increasingly defined by predictable, automated routines, the game invokes the spirit of Dandyism, an intellectual stance that champions originality and spiritual heroism against the mundane. By imposing a highly stylized, playful narrative maze over the physical geography of the city, the interface forces the user to navigate a web of choices, accidents, and sudden turns. Whether the user recovers the device is ultimately irrelevant. The game utilizes structural artifice to jolt the observer out of passive consumption, demanding an active, ironic engagement with the texture and atmosphere of the streets.
</p>

<p>
  By splitting a singular urban landscape into a quantitative network, a qualitative archive, and an interactive narrative, this project expands the historical boundaries of the flâneur. The website functions not as a static repository of data, but as a living amplifier of human perception. It invites you to step inside, wander without a pre-mapped destination, and discover how the digital city re-authors itself within your own mind.
</p>
      </div>
    </section>

    <script>
      // ① FIND OUT 버튼 → 아카이브 섹션
      const startBtn = document.getElementById('start-btn');
      const contentSection = document.getElementById('content-section');
      if (startBtn && contentSection) {
        startBtn.addEventListener('click', () => {
          contentSection.scrollIntoView({ behavior: 'smooth' });
        });
      }

      // ② ABOUT 버튼 → 설명 섹션
      const aboutBtn = document.getElementById('about-btn');
      const aboutSection = document.getElementById('about-section');
      if (aboutBtn && aboutSection) {
        aboutBtn.addEventListener('click', () => {
          aboutSection.scrollIntoView({ behavior: 'smooth' });
        });
      }

      // ③ 카드 등장 애니메이션 (IntersectionObserver)
      const tagContainers = document.querySelectorAll('.luggage-tag-container');
      let hasAnimated = false;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !hasAnimated) {
              hasAnimated = true;
              tagContainers.forEach((tag, index) => {
                setTimeout(() => {
                  tag.classList.add('tag-drop');
                }, index * 180);
              });
              observer.disconnect();
            }
          });
        },
        { threshold: 0.3 }
      );

      if (contentSection) {
        observer.observe(contentSection);
      }
    </script>
  </body>
</html>